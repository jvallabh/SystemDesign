---
import BaseLayout from './BaseLayout.astro';
import FurtherLearning from '../components/FurtherLearning.astro';
import { CATEGORIES } from '../data/categories';
import { withBase } from '../utils/url';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'topics'>;
}

const { entry } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === entry.data.category);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article>
    <header>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={withBase('/')}>Atlas</a>
        <span aria-hidden="true">/</span>
        <span>{category?.title}</span>
      </nav>
      <h1>{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
      {
        entry.data.tier === 'flagship' && (
          <span class="tier-badge">interactive</span>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
    <FurtherLearning keys={entry.data.resources} />
  </article>
</BaseLayout>

<style>
  article {
    max-width: 46rem;
    margin: 0 auto;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.1rem;
    margin: 0 0 0.5rem;
  }

  .summary {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0 0 0.75rem;
  }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-2);
    border: 1px solid var(--accent-2);
    border-radius: 999px;
    padding: 0.2em 0.7em;
  }

  header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .prose :global(h2) {
    margin-top: 2.25rem;
    font-size: 1.4rem;
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.1rem;
  }
</style>
