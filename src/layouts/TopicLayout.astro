---
import BaseLayout from './BaseLayout.astro';
import FurtherLearning from '../components/FurtherLearning.astro';
import { CATEGORIES } from '../data/categories';
import { withBase } from '../utils/url';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'topics'>;
}

const { entry } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === entry.data.category);

let relatedTopics: CollectionEntry<'topics'>[] = [];
if (entry.data.related.length > 0) {
  const all = await getCollection('topics', ({ data }) => !data.draft);
  relatedTopics = entry.data.related
    .map((id) => all.find((t) => t.id === id))
    .filter((t): t is CollectionEntry<'topics'> => t !== undefined);
  // Bad ids are skipped (no chip, no build failure), but log them so typos
  // in `related:` frontmatter show up in the build output.
  if (relatedTopics.length !== entry.data.related.length) {
    const bad = entry.data.related.filter((id) => !all.some((t) => t.id === id));
    console.warn(`[TopicLayout] ${entry.id}: unresolved related ids: ${bad.join(', ')}`);
  }
}
---

<BaseLayout title={entry.data.title} description={entry.data.summary} ogType="article">
  <article>
    <header>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={withBase('/')}>Atlas</a>
        <span aria-hidden="true">/</span>
        <span>{category?.title}</span>
      </nav>
      <h1>{entry.data.title}</h1>
      <p class="summary">{entry.data.summary}</p>
      {
        entry.data.tier === 'flagship' && (
          <span class="tier-badge">interactive</span>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
    <FurtherLearning keys={entry.data.resources} />
    {
      relatedTopics.length > 0 && (
        <section class="related" aria-label="Related concepts">
          <h2>Related concepts</h2>
          <ul>
            {relatedTopics.map((t) => (
              <li>
                <a href={withBase(`/topics/${t.id}/`)}>{t.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  article {
    max-width: 46rem;
    margin: 0 auto;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.1rem;
    margin: 0 0 0.5rem;
  }

  .summary {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0 0 0.75rem;
  }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-2);
    border: 1px solid var(--accent-2);
    border-radius: 999px;
    padding: 0.2em 0.7em;
  }

  header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .prose :global(h2) {
    margin-top: 2.25rem;
    font-size: 1.4rem;
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.1rem;
  }

  .related {
    border-top: 1px solid var(--border);
    margin-top: 2.5rem;
    padding-top: 1.5rem;
  }

  .related h2 {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin: 0 0 0.9rem;
  }

  .related ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .related a {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3em 0.85em;
    text-decoration: none;
  }

  .related a:hover,
  .related a:focus-visible {
    border-color: var(--accent-2);
    background: var(--accent-dim);
  }
</style>
