---
import '../styles/theme.css';
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { withBase } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  wide?: boolean;
}

const {
  title,
  description = 'Interactive explanations of system design concepts.',
  ogType = 'website',
  wide = false,
} = Astro.props;

// Build the absolute page URL with exactly one base prefix, regardless of
// whether Astro.url.pathname already includes it in this build mode.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawPath = Astro.url.pathname;
const pagePath = rawPath === base || rawPath.startsWith(`${base}/`) ? rawPath : `${base}${rawPath}`;
// All pages build as directories (build.format 'directory'), so the served URL
// always ends in '/'. Normalize so canonical/og:url match it (and the sitemap).
const pageUrl = new URL(pagePath.endsWith('/') ? pagePath : `${pagePath}/`, Astro.site).href;
const ogImage = new URL(withBase('/og-card.png'), Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:site_name" content="System Design Atlas" />
    <meta property="og:title" content={`${title} · System Design Atlas`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · System Design Atlas`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title} · System Design Atlas</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      document.documentElement.dataset.theme =
        stored ?? (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="shell">
      <input type="checkbox" id="nav-open" hidden />
      <header class="topbar">
        <label for="nav-open" class="nav-toggle" tabindex="0" role="button" aria-label="Toggle navigation"
          >☰</label
        >
        <script is:inline>
          (() => {
            const toggle = document.querySelector('.nav-toggle');
            const box = document.getElementById('nav-open');
            const sync = () => toggle.setAttribute('aria-expanded', String(box.checked));
            sync();
            box.addEventListener('change', sync);
            toggle.addEventListener('keydown', (e) => {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                box.click(); // toggles the checkbox and fires `change`, unlike setting .checked
              }
            });
          })();
        </script>
        <span class="topbar-title">System Design Atlas</span>
        <ThemeToggle />
      </header>
      <aside>
        <Sidebar />
      </aside>
      <div class="theme-corner">
        <ThemeToggle />
      </div>
      <main id="main" class:list={{ wide }}>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .shell {
    display: grid;
    grid-template-columns: 264px 1fr;
    min-height: 100vh;
  }

  aside {
    border-right: 1px solid var(--border);
    background: var(--bg-inset);
    overflow-y: auto;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  main {
    min-width: 0;
    padding: 2.5rem 3rem 4rem;
  }

  main.wide {
    padding: 1.5rem 1.5rem 2.5rem;
  }

  .topbar {
    display: none;
  }

  .theme-corner {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    z-index: 10;
  }

  @media (max-width: 820px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .theme-corner {
      display: none;
    }

    .topbar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      position: sticky;
      top: 0;
      z-index: 20;
      background: var(--bg-inset);
      border-bottom: 1px solid var(--border);
      padding: 0.6rem 1rem;
    }

    .topbar-title {
      flex: 1;
      font-family: var(--font-mono);
      font-weight: 600;
      font-size: 0.9rem;
    }

    .nav-toggle {
      cursor: pointer;
      font-size: 1.1rem;
      color: var(--text-muted);
    }

    aside {
      display: none;
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    #nav-open:checked ~ aside {
      display: block;
    }

    main {
      padding: 1.5rem 1.25rem 3rem;
    }
  }
</style>
