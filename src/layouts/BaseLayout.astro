---
import '../styles/theme.css';
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { withBase } from '../utils/url';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Interactive explanations of system design concepts.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title} · System Design Atlas</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      document.documentElement.dataset.theme =
        stored ?? (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="shell">
      <input type="checkbox" id="nav-open" hidden />
      <header class="topbar">
        <label for="nav-open" class="nav-toggle" aria-label="Toggle navigation">☰</label>
        <span class="topbar-title">System Design Atlas</span>
        <ThemeToggle />
      </header>
      <aside>
        <Sidebar />
      </aside>
      <div class="theme-corner">
        <ThemeToggle />
      </div>
      <main id="main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .shell {
    display: grid;
    grid-template-columns: 264px 1fr;
    min-height: 100vh;
  }

  aside {
    border-right: 1px solid var(--border);
    background: var(--bg-inset);
    overflow-y: auto;
    position: sticky;
    top: 0;
    height: 100vh;
  }

  main {
    min-width: 0;
    padding: 2.5rem 3rem 4rem;
  }

  .topbar {
    display: none;
  }

  .theme-corner {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    z-index: 10;
  }

  @media (max-width: 820px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .theme-corner {
      display: none;
    }

    .topbar {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      position: sticky;
      top: 0;
      z-index: 20;
      background: var(--bg-inset);
      border-bottom: 1px solid var(--border);
      padding: 0.6rem 1rem;
    }

    .topbar-title {
      flex: 1;
      font-family: var(--font-mono);
      font-weight: 600;
      font-size: 0.9rem;
    }

    .nav-toggle {
      cursor: pointer;
      font-size: 1.1rem;
      color: var(--text-muted);
    }

    aside {
      display: none;
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    #nav-open:checked ~ aside {
      display: block;
    }

    main {
      padding: 1.5rem 1.25rem 3rem;
    }
  }
</style>
