---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { CATEGORIES } from '../data/categories';
import { withBase } from '../utils/url';

const topics = await getCollection('topics', ({ data }) => !data.draft);

const cards = CATEGORIES.map((cat) => {
  const catTopics = topics.filter((t) => t.data.category === cat.slug);
  const first = [...catTopics].sort((a, b) => a.data.order - b.data.order)[0];
  return {
    category: cat,
    topicCount: catTopics.length,
    simCount: catTopics.filter((t) => t.data.tier === 'flagship').length,
    href: first ? withBase(`/topics/${first.id}/`) : withBase('/'),
  };
});

const simTotal = topics.filter((t) => t.data.tier === 'flagship').length;
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>System Design <span class="accent">Atlas</span></h1>
    <p>
      A visual map of the concepts behind large-scale systems — {topics.length} topics with
      original explanations, diagrams, and {simTotal} interactive simulations you can poke at.
    </p>
    <a class="cta" href={withBase('/studio/')}>
      <span aria-hidden="true">⚡</span> Build your own system in the Design Studio
    </a>
  </section>
  <section class="grid">
    {cards.map((c) => <CategoryCard {...c} />)}
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 40rem;
    margin: 2rem auto 3rem;
    text-align: center;
  }

  h1 {
    font-size: 2.6rem;
    margin: 0 0 0.75rem;
  }

  .accent {
    color: var(--accent);
    filter: var(--glow);
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    background: var(--accent-dim);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .cta:hover {
    text-decoration: none;
    background: color-mix(in srgb, var(--accent) 24%, transparent);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    max-width: 62rem;
    margin: 0 auto;
  }

  /* Hero entrance — opacity/transform only, no layout shift after settle. */
  @media (prefers-reduced-motion: no-preference) {
    h1,
    .hero p,
    .grid > :global(*) {
      /* `backwards` fill hides elements during their delay; no `forwards`
         fill so the finished animation releases transform (card hover lift). */
      animation: hero-rise 0.45s ease-out backwards;
    }

    .hero p {
      animation-delay: 80ms;
    }

    .grid > :global(:nth-child(1)) { animation-delay: 160ms; }
    .grid > :global(:nth-child(2)) { animation-delay: 220ms; }
    .grid > :global(:nth-child(3)) { animation-delay: 280ms; }
    .grid > :global(:nth-child(4)) { animation-delay: 340ms; }
    .grid > :global(:nth-child(5)) { animation-delay: 400ms; }
    .grid > :global(:nth-child(6)) { animation-delay: 460ms; }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }
</style>
